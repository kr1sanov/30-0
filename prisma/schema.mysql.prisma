generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Club {
  id        String   @id @default(cuid())
  nameRu    String
  nameEn    String?  @db.VarChar(255)
  city      String?  @db.VarChar(255)
  logoUrl   String?  @db.Text
  seasons   ClubSeason[]

  @@unique([nameRu])
}

model Season {
  id             String   @id @default(cuid())
  startYear      Int
  endYear        Int
  label          String   @db.VarChar(255)
  matchesPerTeam Int      @default(30)
  clubSeasons    ClubSeason[]

  @@unique([startYear, endYear])
}

model ClubSeason {
  id           String   @id @default(cuid())
  clubId       String
  seasonId     String
  position     Int?
  points       Int?
  played       Int?
  won          Int?
  drawn        Int?
  lost         Int?
  goalsFor     Int?
  goalsAgainst Int?

  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  season       Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  players      PlayerSeason[]

  @@unique([clubId, seasonId])
}

model Player {
  id          String   @id @default(cuid())
  lastName    String   @db.VarChar(255)
  firstName   String?  @db.VarChar(255)
  fullName    String   @db.VarChar(255)
  nationality String?  @db.VarChar(255)
  birthYear   Int?

  seasons     PlayerSeason[]

  @@unique([fullName])
}

model PlayerSeason {
  id             String   @id @default(cuid())
  playerId       String
  clubSeasonId   String
  rating         Int
  primeRating    Int      @default(0)
  primeSeason    String?  @db.VarChar(50)
  mainPosition   String   @db.VarChar(50)
  otherPositions String?  @db.VarChar(255)
  age            Int?
  matches        Int?
  goals          Int?
  assists        Int?

  player         Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  clubSeason     ClubSeason @relation(fields: [clubSeasonId], references: [id], onDelete: Cascade)

  @@unique([playerId, clubSeasonId])
}

model User {
  id               String   @id @default(cuid())
  telegramId       String   @unique @db.VarChar(255)
  username         String?  @db.VarChar(255)
  firstName        String?  @db.VarChar(255)
  lastName         String?  @db.VarChar(255)
  photoUrl         String?  @db.Text
  displayName      String   @default("Игрок") @db.VarChar(255)
  profileStatsJson String?  @db.Text

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  referralCode     String?  @unique @db.VarChar(50)
  referredBy       String?  @db.VarChar(50)
  referralCount    Int      @default(0)

  runs             GameRun[]
}

model GameRun {
  id           String   @id @default(cuid())
  formation    String   @default("4-3-3") @db.VarChar(20)
  difficulty   String   @default("normal") @db.VarChar(20)
  draftMode    String   @default("squad_first") @db.VarChar(30)
  ratingMode   String   @default("season") @db.VarChar(20)
  eraFilter    String   @default("all") @db.VarChar(20)
  rerollsTotal Int      @default(1)
  rerollsUsed  Int      @default(0)

  completed    Boolean  @default(false)
  wins         Int?
  draws        Int?
  losses       Int?
  points       Int?
  position     Int?
  goalsFor     Int?
  goalsAgainst Int?
  overallRating Int?

  managerName   String?  @db.VarChar(255)
  managerRating Int?
  teamName      String?  @db.VarChar(255)

  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())

  eraStartYear   Int      @default(2000)
  eraEndYear     Int      @default(2025)
  clubFilter     String?  @db.VarChar(255)

  slots        GameSlot[]
}

model GameSlot {
  id                   String   @id @default(cuid())
  runId                String
  slotPosition         String   @db.VarChar(20)
  playerSeasonId       String?
  playerName           String?  @db.VarChar(255)
  playerLastName       String?  @db.VarChar(255)
  playerRating         Int?
  playerPrimeRating    Int?
  playerPosition       String?  @db.VarChar(50)
  playerOtherPositions String?  @db.VarChar(255)
  playerNationality    String?  @db.VarChar(255)
  isCompatible         Boolean  @default(true)

  run                  GameRun  @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, slotPosition])
}

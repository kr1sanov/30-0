# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep .env.example, ignore the rest
.env
.env.local
.env.production
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config

# logs
*.log
dev.log
dev.out.log
server.log

# database
db/*.db
db/*.db-journal

# docker
docker-compose.override.yml

# test & prompt
test
prompt

# Skills directory
/skills/

# Prisma migrations are tracked in git
!prisma/migrations/

# ──────────────────────────────────────────────
# 30-0 RPL — Apache .htaccess for Jino Production
# ──────────────────────────────────────────────
# This file configures Apache to serve the Next.js app
# with proper security headers and caching.
# ──────────────────────────────────────────────

# ─── Security Headers ───

# Prevent clickjacking
Header always set X-Frame-Options "SAMEORIGIN"

# Prevent MIME-type sniffing
Header always set X-Content-Type-Options "nosniff"

# XSS Protection (legacy, but still useful for older browsers)
Header always set X-XSS-Protection "1; mode=block"

# Referrer Policy
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# HSTS — force HTTPS
Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

# Permissions Policy — disable unused features
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

# Content Security Policy
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://telegram.org https://mc.yandex.ru; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https: http:; font-src 'self' data:; connect-src 'self' https://mc.yandex.ru https://api.telegram.org; frame-src https://web.telegram.org; object-src 'none'; base-uri 'self'"

# ─── Remove X-Powered-By header ───
Header always unset X-Powered-By

# ─── Caching ───

# Cache static assets for 1 year
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Static Next.js assets — immutable cache
<IfModule mod_rewrite.c>
  # _next/static assets — 1 year immutable
  <FilesMatch "\.next/static/">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# ─── Compression ───

# Enable Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ─── Phusion Passenger Configuration ───

# Set the Node.js entry point for Passenger
PassengerNodejs /usr/bin/node
PassengerAppRoot /home/j97915155/30-0

# Set the startup file
PassengerStartupFile .next/standalone/server.js

# Environment variables
PassengerEnvVar NODE_ENV production
PassengerEnvVar PORT 3000

# ─── Rewrite Rules ───

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Route all requests through Next.js
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ / [L,QSA]
</IfModule>

# ─── Error Pages ───
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html
